# Discord Bot
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# LLM Provider — any OpenAI-compatible API
# Local llama.cpp (no key needed):
#   LLAMA_API_URL=http://host.docker.internal:8080/v1
#   LLAMA_MODEL_ID=qwen3-coder
#   LLM_API_KEY=
# OpenRouter (free tier example):
#   LLAMA_API_URL=https://openrouter.ai/api/v1
#   LLAMA_MODEL_ID=nvidia/nemotron-3-super-120b-a12b:free
#   LLM_API_KEY=sk-or-v1-...
LLAMA_API_URL=http://host.docker.internal:8080/v1
LLAMA_MODEL_ID=qwen3-coder
LLM_API_KEY=

# OpenCode Server
OPENCODE_URL=http://opencode:4096
OPENCODE_SERVER_PASSWORD=change-me-to-something-secure
OPENCODE_SERVER_USERNAME=opencode

# Bot Personality (or path to a .txt file in bot/personalities/)
BOT_PERSONALITY=helpful engineer
